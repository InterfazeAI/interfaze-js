{
  "name": "interfaze",
  "version": "1.0.1",
  "description": "Interfaze Javascript/Typescript SDK",
  "license": "MIT",
  "author": "Interfaze",
  "homepage": "https://interfaze.ai",
  "repository": { "type": "git", "url": "git+https://github.com/InterfazeAI/interfaze-js.git" },
  "keywords": ["interfaze", "openai", "ai", "ocr", "speech-to-text", "web-search", "sdk"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "qa:live": "tsx scripts/qa-live.ts",
    "prepare": "tsup",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "openai": "~6.47.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.4.3"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "~22.20.1",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9",
    "zod": "^4.4.3"
  }
}
